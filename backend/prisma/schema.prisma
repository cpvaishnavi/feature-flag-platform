datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String
  createdAt DateTime @default(now())
}

model FeatureFlag {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdBy   Int
  rollout     Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model FlagRule {
  id                Int  @id @default(autoincrement())
  flagId            Int
  rolloutPercentage Int
  conditions        Json?
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  flagId    Int
  action    String
  userId    Int
  timestamp DateTime @default(now())
}